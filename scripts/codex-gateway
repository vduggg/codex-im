#!/usr/bin/env bash
set -euo pipefail

LABEL="com.yuan.feishu-bridge"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
DOMAIN="gui/$(id -u)"
SERVICE="${DOMAIN}/${LABEL}"
PLUGIN_DIR="$HOME/.codex/plugins/yuan-feishu"
PROCESS_PATTERN="plugins/yuan-feishu/bin/codex-im.js feishu-bot"
OUT_LOG="${PLUGIN_DIR}/logs/launchd.out.log"
ERR_LOG="${PLUGIN_DIR}/logs/launchd.err.log"
GREEN=$'\033[1;32m'
RED=$'\033[1;31m'
YELLOW=$'\033[1;33m'
RESET=$'\033[0m'

usage() {
  cat <<'USAGE'
Yuan Feishu Gateway control

Usage:
  codex-gateway status
  codex-gateway restart
  codex-gateway stop
  codex-gateway start
  codex-gateway logs

This controls only com.yuan.feishu-bridge. It does not stop or modify
the Codex desktop app.
USAGE
}

service_loaded() {
  launchctl print "$SERVICE" >/dev/null 2>&1
}

print_header() {
  printf '\n== %s ==\n' "$1"
}

print_processes() {
  print_header "Gateway process"
  ps aux | grep -E "$PROCESS_PATTERN" | grep -v grep || true
}

get_gateway_process() {
  ps aux | grep -E "$PROCESS_PATTERN" | grep -v grep || true
}

get_launchctl_field() {
  local field="$1"
  launchctl print "$SERVICE" 2>/dev/null | awk -v field="$field" '$1 == field { print $3; exit }'
}

print_status_line() {
  local label="$1"
  local value="$2"
  printf '  %-18s %s\n' "$label" "$value"
}

wait_for_running() {
  local attempts=10
  local state=""
  local process_line=""
  while (( attempts > 0 )); do
    state="$(get_launchctl_field state || true)"
    process_line="$(get_gateway_process)"
    if [[ "$state" == "running" && -n "$process_line" ]]; then
      return 0
    fi
    sleep 1
    attempts=$((attempts - 1))
  done
  return 0
}

strip_ansi() {
  sed -E $'s/\x1B\\[[0-9;]*[A-Za-z]//g'
}

health_status() {
  local loaded="no"
  local state="not loaded"
  local pid="-"
  local process_line=""
  local run_at_load="unknown"
  local keep_alive="unknown"
  local recent_ready="no"
  local recent_errors="0"

  if service_loaded; then
    loaded="yes"
    state="$(get_launchctl_field state || true)"
    pid="$(get_launchctl_field pid || true)"
    [[ -n "$state" ]] || state="unknown"
    [[ -n "$pid" ]] || pid="-"
  fi

  process_line="$(get_gateway_process)"

  if [[ -f "$PLIST" ]]; then
    run_at_load="$(/usr/libexec/PlistBuddy -c 'Print :RunAtLoad' "$PLIST" 2>/dev/null || echo unknown)"
    keep_alive="$(/usr/libexec/PlistBuddy -c 'Print :KeepAlive' "$PLIST" 2>/dev/null || echo unknown)"
  fi

  if [[ -f "$OUT_LOG" ]]; then
    local recent_out
    recent_out="$(tail -c 200000 "$OUT_LOG" 2>/dev/null || true)"
    if grep -Eq "ws client ready|Feishu long connection started|feishu-bot runtime ready|turn/start ok|turn/completed" <<<"$recent_out"; then
      recent_ready="yes"
    fi
  fi

  if [[ -f "$ERR_LOG" ]]; then
    recent_errors="$(tail -n 120 "$ERR_LOG" | grep -Eci "error|failed|timeout|ENOTFOUND|disconnected|reset" || true)"
  fi

  print_header "Yuan Feishu Gateway Status"

  local healthy="no"
  if [[ "$loaded" == "yes" && "$state" == "running" && -n "$process_line" ]]; then
    healthy="yes"
    printf "%s🟢 ✅ GATEWAY 正常运行%s\n" "$GREEN" "$RESET"
  elif [[ "$loaded" == "yes" ]]; then
    printf "%s❌ GATEWAY 出问题了：服务已加载，但进程不健康%s\n" "$RED" "$RESET"
  else
    printf "%s❌ GATEWAY 未运行%s\n" "$RED" "$RESET"
  fi

  echo
  print_status_line "Service" "$LABEL"
  print_status_line "LaunchAgent" "$state"
  print_status_line "PID" "$pid"
  print_status_line "Process" "$([[ -n "$process_line" ]] && echo running || echo missing)"
  print_status_line "Auto start" "$([[ "$run_at_load" == "true" ]] && echo enabled || echo "$run_at_load")"
  print_status_line "Auto recover" "$([[ "$keep_alive" == "true" ]] && echo enabled || echo "$keep_alive")"
  print_status_line "Feishu link" "$([[ "$recent_ready" == "yes" ]] && echo 'recently ready' || echo 'not confirmed in recent logs')"
  if [[ "$recent_errors" == "0" ]]; then
    print_status_line "Log warnings" "none in recent stderr"
  elif [[ "$healthy" == "yes" && "$recent_ready" == "yes" ]]; then
    print_status_line "Log warnings" "old warnings found; current status is OK"
  else
    print_status_line "Log warnings" "$recent_errors warning/error lines in recent stderr"
  fi

  echo
  if [[ "$recent_errors" != "0" && "$healthy" != "yes" ]]; then
    echo "Error hints:"
    tail -n 120 "$ERR_LOG" 2>/dev/null \
      | grep -Ei "error|failed|timeout|ENOTFOUND|disconnected|reset" \
      | tail -n 5 \
      | strip_ansi \
      | sed 's/^/  - /' || true
    echo
  fi

  echo "Useful next steps:"
  echo "  - If status is OK: nothing to do."
  echo "  - If it is stuck: run 'codex-gateway restart'."
  echo "  - If you want details: run 'codex-gateway logs'."
  echo
  echo "Safety boundary: this controls only the Feishu Gateway, not the Codex desktop app."
}

status() {
  health_status
}

start_gateway() {
  if service_loaded; then
    echo "Gateway is already loaded. Starting/kicking it now..."
  else
    if [[ ! -f "$PLIST" ]]; then
      echo "Missing plist: $PLIST" >&2
      exit 1
    fi
    launchctl bootstrap "$DOMAIN" "$PLIST"
    launchctl enable "$SERVICE"
  fi
  launchctl kickstart -k "$SERVICE"
  wait_for_running
  echo "Gateway started."
  status
}

stop_gateway() {
  if service_loaded; then
    launchctl bootout "$DOMAIN" "$PLIST"
    echo "Gateway stopped."
  else
    echo "Gateway is already stopped."
  fi
  print_processes
}

restart_gateway() {
  if service_loaded; then
    launchctl kickstart -k "$SERVICE"
  else
    start_gateway
    return
  fi
  echo "Gateway restarted."
  wait_for_running
  status
}

logs() {
  print_header "stdout tail"
  tail -n 80 "$OUT_LOG" 2>/dev/null || echo "No stdout log: $OUT_LOG"
  print_header "stderr tail"
  tail -n 80 "$ERR_LOG" 2>/dev/null || echo "No stderr log: $ERR_LOG"
}

case "${1:-}" in
  status) status ;;
  restart) restart_gateway ;;
  stop) stop_gateway ;;
  start) start_gateway ;;
  logs) logs ;;
  -h|--help|help|"") usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
