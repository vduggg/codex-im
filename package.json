{
  "name": "yuan-feishu",
  "version": "0.2.2",
  "description": "Private Yuan Feishu bridge for local Codex.",
  "license": "MIT",
  "type": "commonjs",
  "main": "src/index.js",
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "bot",
    "cli",
    "remote"
  ],
  "files": [
    "bin",
    "scripts",
    "src",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "yuan-feishu": "./bin/codex-im.js",
    "codex-im": "./bin/codex-im.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "feishu-bot": "node ./bin/codex-im.js",
    "check": "find src bin scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test:markdown": "node ./scripts/test-assistant-markdown.js",
    "test:directives": "node ./scripts/test-outbound-directives.js",
    "test:media": "node ./scripts/test-media-fixtures.js",
    "test:plan": "node ./scripts/test-plan-mode.js",
    "test:queue": "node ./scripts/test-message-queue.js",
    "smoke:feishu-media": "node ./scripts/feishu-media-smoke.js"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.54.0",
    "dotenv": "^16.4.7",
    "ws": "^8.19.0"
  }
}
