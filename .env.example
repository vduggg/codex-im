# Feishu app credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Codex model
CODEX_IM_DEFAULT_CODEX_MODEL=gpt-5.3-codex
CODEX_IM_DEFAULT_CODEX_EFFORT=medium
CODEX_IM_DEFAULT_CODEX_ACCESS_MODE=default

# Bot behavior
CODEX_IM_DEFAULT_WORKSPACE_ID=default
# Whether Feishu replies are streamed in real time.
# true  = stream card updates (default)
# false = send once after run completes
CODEX_IM_FEISHU_STREAMING_OUTPUT=true
# Whether normal assistant replies use Feishu CardKit element streaming.
# true  = smooth CardKit streaming card without the red header (default)
# false = use the legacy interactive card patch path
CODEX_IM_FEISHU_CARDKIT_STREAMING=true

# Restrict which local directories can be bound from Feishu
# Comma-separated absolute paths. Leave empty to allow any absolute path.
CODEX_IM_WORKSPACE_ALLOWLIST=

# Optional explicit Codex endpoint. Leave empty to spawn `codex app-server`.
CODEX_IM_CODEX_ENDPOINT=

# Optional session persistence location
CODEX_IM_SESSIONS_FILE=/Users/your-name/.codex-im/sessions.json

# Optional private attachment cache for Feishu image intake
CODEX_IM_ATTACHMENTS_DIR=/Users/your-name/.codex/yuan-feishu/attachments
CODEX_IM_MAX_IMAGE_BYTES=10485760
CODEX_IM_MAX_ATTACHMENT_BYTES=104857600

# Optional image understanding fallback.
# If Codex app-server cannot accept native multimodal input, the bridge uses this
# to turn Feishu images into text context before sending the turn to Codex.
CODEX_IM_VISION_ENABLED=true
# codex-cli reuses this machine's Codex model/provider/auth; responses uses an API key.
CODEX_IM_VISION_PROVIDER=codex-cli
CODEX_IM_VISION_CODEX_COMMAND=/opt/homebrew/bin/codex
CODEX_IM_VISION_API_KEY=
CODEX_IM_VISION_BASE_URL=https://api.openai.com/v1
# Leave empty to follow the current Codex model selected for the bound workspace.
CODEX_IM_VISION_MODEL=
CODEX_IM_VISION_TIMEOUT_MS=60000
CODEX_IM_VISION_MAX_OUTPUT_TOKENS=800
